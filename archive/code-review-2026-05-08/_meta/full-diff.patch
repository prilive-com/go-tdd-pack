+    .editorconfig|*/.editorconfig|.gitignore|*/.gitignore) return 0 ;;
+    go.sum|*/go.sum) return 0 ;;
+    .github/*|*/.github/*|.gitlab-ci.yml|*/.gitlab-ci.yml) return 0 ;;
+    .tdd/*|*/.tdd/*) return 0 ;;
+    .claude/*|*/.claude/*) return 0 ;;
+    .second-opinion/*|*/.second-opinion/*) return 0 ;;
+  esac
+  return 1
