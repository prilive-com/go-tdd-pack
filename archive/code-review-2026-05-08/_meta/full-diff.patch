+# shapes plus future variants with .files[] / .edits[].file_path.
+mapfile -t paths < <(jq -r '
+  [
+    .tool_input.file_path?,
+    .tool_input.path?,
+    (.tool_input.files[]?.file_path?),
+    (.tool_input.edits[]?.file_path?)
+  ] | map(select(. != null and . != "")) | unique | .[]
