{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_v2_cutover_note": "Cut over from v1.x ceremony hooks to v2.0 MVP at 2026-05-16. v1.x backup at .claude/settings.json.v1.x.backup. v1.x hook scripts remain on disk at .claude/hooks/* but are no longer registered. Phase 2 (2026-05-16) added Stop + SessionStart hooks for rounds 2+ orchestration and resume notification.",
  "enableAllProjectMcpServers": false,
  "enabledMcpjsonServers": [
    "gopls"
  ],
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(gofmt -w *)",
      "Bash(gofmt -l *)",
      "Bash(goimports *)",
      "Bash(go list *)",
      "Bash(go test ./...)",
      "Bash(go test -race ./...)",
      "Bash(go test -race -count=1 ./...)",
      "Bash(go test -count=1 ./...)",
      "Bash(go vet ./...)",
      "Bash(go mod tidy)",
      "Bash(go version)",
      "Bash(make *)",
      "Bash(rg *)",
      "Bash(grep *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git blame *)",
      "Bash(git branch *)",
      "Bash(git show *)"
    ],
    "ask": [
      "Edit(migrations/**)",
      "Write(migrations/**)",
      "Edit(.github/workflows/**)",
      "Write(.github/workflows/**)",
      "Edit(.gitlab-ci.yml)",
      "Write(.gitlab-ci.yml)",
      "Bash(go build *)",
      "Bash(go run *)",
      "Bash(go install *)",
      "Bash(go get *)",
      "Bash(golangci-lint run *)",
      "Bash(staticcheck *)",
      "Bash(govulncheck *)",
      "Bash(deadcode *)",
      "Bash(unparam *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git push origin *)",
      "Bash(git push --force-with-lease *)",
      "Bash(git tag *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./private/**)",
      "Read(./credentials/**)",
      "Read(./config/credentials.json)",
      "Read(./config/**/credentials*.json)",
      "Read(./config/**/*secret*)",
      "Read(./config/**/*token*)",
      "Read(./**/id_rsa*)",
      "Read(./**/id_ed25519*)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)",
      "Edit(./.git/**)",
      "Write(./.git/**)",
      "Edit(.claude/settings.json)",
      "Write(.claude/settings.json)",
      "Edit(.tdd/reviews/**)",
      "Write(.tdd/reviews/**)",
      "MultiEdit(.tdd/reviews/**)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(rm -rf $HOME*)",
      "Bash(sudo *)",
      "Bash(chmod 777 *)",
      "Bash(chmod -R 777 *)",
      "Bash(curl * | sh)",
      "Bash(curl * | bash)",
      "Bash(wget * | sh)",
      "Bash(wget * | bash)",
      "Bash(* --no-verify *)",
      "Bash(*--no-verify)",
      "Bash(git commit --no-verify*)",
      "Bash(git commit -n *)",
      "Bash(HUSKY=0 *)",
      "Bash(GIT_HOOKS=0 *)",
      "Bash(SKIP=* git commit *)",
      "Bash(git push * --force *)",
      "Bash(git push *--force)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git push *-f)",
      "Bash(git filter-repo *)",
      "Bash(git filter-branch *)",
      "Bash(git reset --hard origin/*)",
      "Bash(* --accept-data-loss *)",
      "Bash(*--accept-data-loss)",
      "Bash(psql *production*)",
      "Bash(psql *prod-*)",
      "Bash(mysql *production*)",
      "Bash(mongo *production*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/guard-dangerous-bash.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/guard-bash-pipefail.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/guard-protected-files.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/scan-for-secrets.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/hooks/pre-review.sh",
            "timeout": 120
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/gofmt-after-edit.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/detect-ai-bloat.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/hooks/post-edit-review.sh",
            "async": true,
            "timeout": 5
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/hooks/inject-findings.sh",
            "timeout": 3
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/hooks/post-edit-review.sh",
            "async": true,
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/hooks/inject-findings.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/hooks/stop-fingerprint.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/hooks/session-start.sh",
            "timeout": 3
          }
        ]
      }
    ]
  }
}
