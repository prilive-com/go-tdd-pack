# Per-repo configuration for github-setup scripts.
# Copy this file to scripts/github/repo-config.env in your repo, edit, source it.
# Or pass overrides as environment variables: REPO_NAME=other-repo ./setup.sh

# Organization and repo
ORG="prilive-com"
REPO_NAME="go-tdd-pack"

# Visibility (the scripts always create private; this is post-public confirmation only)
TARGET_VISIBILITY="public"   # "public" or stay "private"

# Metadata
REPO_DESCRIPTION="Continuous silent peer review between Claude Code and OpenAI Codex CLI for Go projects"
REPO_HOMEPAGE="https://github.com/prilive-com/go-tdd-pack"
DEFAULT_BRANCH="main"

# Topics (comma-separated, no spaces around commas)
REPO_TOPICS="go,golang,claude-code,codex-cli,tdd,ai-assisted-development,code-review,developer-tools,peer-review,plugin"

# Features
HAS_ISSUES=true
HAS_PROJECTS=false        # Use GitHub Projects? Most solo OSS projects don't
HAS_WIKI=false            # Use docs/ in repo instead
HAS_DISCUSSIONS=true      # Useful for OSS user questions

# Merge policy
ALLOW_SQUASH_MERGE=true
ALLOW_MERGE_COMMIT=false
ALLOW_REBASE_MERGE=false
ALLOW_AUTO_MERGE=true
DELETE_BRANCH_ON_MERGE=true
SQUASH_MERGE_COMMIT_TITLE="PR_TITLE"
SQUASH_MERGE_COMMIT_MESSAGE="PR_BODY"

# Security
WEB_COMMIT_SIGNOFF_REQUIRED=true   # DCO sign-off on web UI commits
ENABLE_PVR=true                     # Private Vulnerability Reporting
ENABLE_DEPENDABOT_ALERTS=true
ENABLE_DEPENDABOT_SECURITY_UPDATES=true
ENABLE_SECRET_SCANNING=true
ENABLE_SECRET_SCANNING_PUSH_PROTECTION=true

# Code scanning (CodeQL default setup)
ENABLE_CODEQL=true
CODEQL_LANGUAGES="go"   # comma-separated

# Branch protection ruleset
RULESET_NAME="balanced-solo-maintainer"
REQUIRED_STATUS_CHECKS="test,lint,CodeQL"   # GitHub Actions check_run names are just the job name (no workflow prefix); CodeQL from default setup. Add "DCO" back here once the cncf/dco2 GitHub App is installed at the org level (https://github.com/apps/dco).
RULESET_REQUIRE_LINEAR_HISTORY=true
RULESET_REQUIRE_SIGNATURES=false   # set true only if all commits will be GPG-signed (not just DCO)
RULESET_REQUIRE_CONVERSATION_RESOLUTION=true
RULESET_BYPASS_FOR_ADMIN=true      # solo maintainer can bypass via PR-mode

# Tag protection ruleset (release tags v*)
TAG_RULESET_NAME="protect-release-tags"
TAG_RULESET_PATTERN="refs/tags/v*"

# Actions permissions
ACTIONS_DEFAULT_TOKEN_PERMISSIONS="read"   # GITHUB_TOKEN default = read-only
ACTIONS_CAN_APPROVE_PULL_REQUESTS=false

# Token (do NOT commit this file with the token populated)
# Set GH_BASELINE_TOKEN in your shell or load from keychain:
#   macOS:   export GH_BASELINE_TOKEN=$(security find-generic-password -s gh-baseline -w)
#   Linux:   export GH_BASELINE_TOKEN=$(secret-tool lookup service gh-baseline)
#   1Password: export GH_BASELINE_TOKEN=$(op read "op://Private/gh-baseline/token")
