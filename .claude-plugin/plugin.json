{
  "name": "prilive-go-tdd-pack",
  "version": "2.2.0",
  "description": "Finding-aware continuous code review + opt-in runtime ops-safety triage for Go projects. Claude implements; OpenAI Codex CLI reviews in the background. v2.1 added four false-positive rails, verify-only later rounds, Gate 4 artifact protection, the FDTDD active-finding foundation, MCP detachment for structured-output calls, and origin-aware escalation. v2.2 added the Ops Risk Triage rail: a three-layer Bash-command gate (deterministic parser → fast Haiku classifier → Codex deep ops-preflight) with ask/governed modes, session-tag-driven R2→R3 escalation (the specific fix for chown→rebuild outages), and ops-debt accounting via Stop-hook block. Default off; pure opt-in.",
  "author": {
    "name": "Prilive",
    "url": "https://github.com/prilive-com"
  },
  "license": "Apache-2.0",
  "homepage": "https://github.com/prilive-com/go-tdd-pack",
  "repository": {
    "type": "git",
    "url": "https://github.com/prilive-com/go-tdd-pack"
  },
  "bugs": {
    "url": "https://github.com/prilive-com/go-tdd-pack/issues"
  },
  "keywords": [
    "go",
    "golang",
    "code-review",
    "peer-review",
    "codex",
    "continuous-review",
    "tdd",
    "finding-driven-tdd",
    "monorepo",
    "static-analysis",
    "staticcheck",
    "golangci-lint",
    "govulncheck"
  ],
  "categories": ["code-quality", "review"],
  "engines": {
    "claude-code": ">=2.1.89"
  },
  "requires": {
    "codex-cli": ">=0.125.0",
    "go": ">=1.22.0",
    "git": ">=2.25.0",
    "bash": ">=4.0",
    "jq": ">=1.6"
  },
  "recommends": {
    "staticcheck": "honnef.co/go/tools/cmd/staticcheck@latest",
    "golangci-lint": "https://golangci-lint.run/welcome/install/",
    "govulncheck": "golang.org/x/vuln/cmd/govulncheck@latest"
  },
  "config_file": "tdd-pack.toml",
  "commands": [
    {
      "name": "show-review",
      "description": "Show the most recent Codex review cycle with all findings, verdict, and current state"
    },
    {
      "name": "abandon-review",
      "description": "Abandon the current review cycle so future edits start fresh"
    },
    {
      "name": "accept-claude",
      "description": "After an A/B/V escalation, accept Claude's version (ship as-is)"
    },
    {
      "name": "accept-codex",
      "description": "After an A/B/V escalation, accept Codex's recommendations and apply them"
    }
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/protect-tdd-artifacts.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/pre-review.sh",
            "timeout": 120
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/ops-risk-triage.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/ops-debt-track.sh",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/ops-tag-session.sh",
            "timeout": 3
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/post-edit-review.sh",
            "async": true,
            "timeout": 5
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/inject-findings.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/inject-findings.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/stop-fingerprint.sh",
            "async": true,
            "timeout": 5
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/ops-debt-stop.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/session-start.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "documentation": {
    "readme": "README.md",
    "guides": [
      { "name": "Adoption Guide", "path": "docs/ADOPTION_GUIDE.md" },
      { "name": "AI Developer Guide", "path": "docs/AI_DEVELOPER_GUIDE.md" },
      { "name": "Integration Guide", "path": "docs/INTEGRATION_GUIDE.md" },
      { "name": "Monorepo Adoption Guide", "path": "docs/MONOREPO_ADOPTION_GUIDE.md" },
      { "name": "V2 Implementation Spec", "path": "docs/V2_IMPLEMENTATION_SPEC.md" },
      { "name": "V2 Rollout Guide", "path": "docs/V2_ROLLOUT_GUIDE.md" }
    ]
  },
  "security": {
    "policy": "SECURITY.md"
  }
}
